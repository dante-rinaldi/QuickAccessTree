<Window x:Class="SidebarBuddy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SidebarBuddy.Converters"
        xmlns:models="clr-namespace:SidebarBuddy.Models"
        Title="Sidebar Buddy"
        Width="220"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Left="-32000" Top="0"
        PreviewMouseDown="Window_PreviewMouseDown">

    <Window.Resources>
        <conv:ColorToBrushConverter x:Key="ColorToBrush"/>

        <!-- Expand/collapse chevron on tree nodes -->
        <Style x:Key="ChevronToggle" TargetType="ToggleButton">
            <Setter Property="Focusable"       Value="False"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"  Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent">
                            <Path x:Name="Ch"
                                  Data="M 6 4 L 11 9 L 6 14"
                                  Stroke="{DynamicResource Theme.DimText}" StrokeThickness="1.5"
                                  StrokeLineJoin="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ch" Property="Data"   Value="M 4 7 L 9 12 L 14 7"/>
                                <Setter TargetName="Ch" Property="Stroke" Value="#9CDCFE"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ch" Property="Stroke" Value="{DynamicResource Theme.SecondaryText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeViewItem template -->
        <Style x:Key="FolderItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded"
                    Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Row"
                                    Background="Transparent"
                                    CornerRadius="4"
                                    Margin="4,1,6,1"
                                    Padding="0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton Grid.Column="0"
                                                  Style="{StaticResource ChevronToggle}"
                                                  x:Name="Expander"
                                                  IsChecked="{Binding IsExpanded,
                                                      RelativeSource={RelativeSource TemplatedParent},
                                                      Mode=TwoWay}"
                                                  ClickMode="Press"
                                                  Visibility="Hidden"/>

                                    <Viewbox x:Name="FolderIcon"
                                             Grid.Column="1"
                                             Width="16" Height="13"
                                             VerticalAlignment="Center">
                                        <Canvas Width="20" Height="16">
                                            <Path Data="M1,5 L7,5 L9,3 L1,3 Z"
                                                  Fill="{Binding Color,
                                                      Converter={StaticResource ColorToBrush}}"/>
                                            <Path Data="M1,5 L1,15 L19,15 L19,5 Z"
                                                  Fill="{Binding Color,
                                                      Converter={StaticResource ColorToBrush}}"/>
                                            <Path Data="M1,5 L19,5"
                                                  Stroke="#40FFFFFF"
                                                  StrokeThickness="1"/>
                                        </Canvas>
                                    </Viewbox>

                                    <TextBlock x:Name="FolderLabel"
                                               Grid.Column="2"
                                               Text="{Binding Name}"
                                               Foreground="{DynamicResource Theme.PrimaryText}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>

                            <ItemsPresenter x:Name="Items"
                                            Margin="10,0,0,0"
                                            Visibility="Collapsed"/>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Expander"
                                        Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="Items"
                                        Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row"
                                        Property="Background" Value="{DynamicResource Theme.ItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Row"
                                        Property="Background" Value="{DynamicResource Theme.ItemSelect}"/>
                            </Trigger>
                            <!-- Group header: outline border, bold label, no folder icon -->
                            <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                <Setter TargetName="FolderIcon" Property="Visibility"  Value="Collapsed"/>
                                <Setter TargetName="FolderLabel" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Row" Property="BorderBrush"     Value="{DynamicResource Theme.BorderSoft}"/>
                                <Setter TargetName="Row" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="Row" Property="Padding"         Value="0,4"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small header icon-button -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource Theme.DimText}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Width"  Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.ItemHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Theme.SecondaryText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slim scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource Theme.ScrollThumb}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ═══ EXPANDED sidebar ════════════════════════════════════════ -->
        <Border x:Name="OuterBorder"
                Background="{DynamicResource Theme.SidebarBg}"
                CornerRadius="6,0,0,6"
                BorderBrush="{DynamicResource Theme.BorderBrush}"
                BorderThickness="1,1,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="38"/>
                </Grid.RowDefinitions>

                <!-- Header — drag to move Explorer -->
                <Border Grid.Row="0"
                        x:Name="HeaderBorder"
                        Background="{DynamicResource Theme.HeaderBg}"
                        CornerRadius="6,0,0,0"
                        BorderBrush="{DynamicResource Theme.BorderBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="Header_DragStart"
                        MouseMove="Header_DragMove"
                        MouseLeftButtonUp="Header_DragEnd"
                        Cursor="SizeAll">
                    <DockPanel Margin="8,0,4,0" LastChildFill="True">
                        <!-- Collapse sidebar -->
                        <Button x:Name="CollapseBtn"
                                Style="{StaticResource IconBtn}"
                                DockPanel.Dock="Right"
                                ToolTip="Collapse sidebar"
                                Click="CollapseBtn_Click"
                                Content="◀"/>
                        <!-- Dock side toggle -->
                        <Button x:Name="DockToggleBtn"
                                Style="{StaticResource IconBtn}"
                                DockPanel.Dock="Right"
                                ToolTip="Swap dock side"
                                Click="DockToggleBtn_Click"
                                Content="⇄"/>
                        <!-- Remove selected folder -->
                        <Button x:Name="RemoveBtn"
                                Style="{StaticResource IconBtn}"
                                DockPanel.Dock="Right"
                                ToolTip="Remove selected folder"
                                Click="RemoveBtn_Click"
                                Content="🗑"
                                FontSize="11"
                                IsEnabled="False"/>
                        <!-- Settings -->
                        <Button x:Name="SettingsBtn"
                                Style="{StaticResource IconBtn}"
                                DockPanel.Dock="Right"
                                ToolTip="Settings"
                                Click="SettingsBtn_Click"
                                Content="⚙"/>
                        <TextBlock Text="Sidebar Buddy"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="{DynamicResource Theme.SecondaryText}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Content area — quick links + tree -->
                <DockPanel Grid.Row="1">

                    <!-- Quick links pinned to top -->
                    <Border x:Name="QuickLinksTopPanel"
                            DockPanel.Dock="Top"
                            Visibility="Collapsed"
                            Background="{DynamicResource Theme.HeaderBg}"
                            BorderBrush="{DynamicResource Theme.BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel x:Name="QuickLinksTopContent" Margin="6,4,6,4"/>
                    </Border>

                    <!-- Quick links pinned to bottom -->
                    <Border x:Name="QuickLinksBottomPanel"
                            DockPanel.Dock="Bottom"
                            Visibility="Collapsed"
                            Background="{DynamicResource Theme.HeaderBg}"
                            BorderBrush="{DynamicResource Theme.BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel x:Name="QuickLinksBottomContent" Margin="6,4,6,4"/>
                    </Border>

                    <!-- Folder tree -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <TreeView x:Name="FolderTree"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0,4,0,4"
                              AllowDrop="True"
                              ItemContainerStyle="{StaticResource FolderItemStyle}"
                              SelectedItemChanged="FolderTree_SelectedItemChanged"
                              PreviewMouseRightButtonDown="FolderTree_PreviewRightClick"
                              PreviewMouseLeftButtonDown="FolderTree_PreviewLeftDown"
                              PreviewMouseMove="FolderTree_PreviewMouseMove"
                              DragOver="FolderTree_DragOver"
                              DragLeave="FolderTree_DragLeave"
                              Drop="FolderTree_Drop">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type models:FolderNode}"
                                                      ItemsSource="{Binding Children}">
                                <Grid/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ContextMenu>
                            <ContextMenu x:Name="TreeCtxMenu">
                                <MenuItem Header="Open in Explorer"  Click="CtxOpen_Click"/>
                                <Separator/>
                                <MenuItem Header="Change color…"     Click="CtxColor_Click"/>
                                <MenuItem Header="Rename…"           Click="CtxRename_Click"/>
                                <Separator/>
                                <MenuItem Header="Add folder…"       Click="CtxAdd_Click"/>
                                <MenuItem x:Name="CtxRemoveItem"
                                          Header="Remove"
                                          Click="CtxRemove_Click"/>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                    </ScrollViewer>
                </DockPanel>

                <!-- Footer -->
                <Border Grid.Row="2"
                        x:Name="FooterBorder"
                        Background="{DynamicResource Theme.HeaderBg}"
                        CornerRadius="0,0,0,6"
                        BorderBrush="{DynamicResource Theme.BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="8,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Add Group button -->
                        <Button Grid.Column="0"
                                Content="＋ Group"
                                Height="26"
                                Background="{DynamicResource Theme.ItemHover}"
                                Foreground="{DynamicResource Theme.SecondaryText}"
                                BorderBrush="{DynamicResource Theme.BorderSoft}"
                                BorderThickness="1"
                                FontSize="11"
                                Cursor="Hand"
                                Click="AddGroupBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.ItemSelect}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Add Folder button -->
                        <Button Grid.Column="2"
                                Content="＋ Folder"
                                Height="26"
                                Background="{DynamicResource Theme.ItemHover}"
                                Foreground="#9CDCFE"
                                BorderBrush="{DynamicResource Theme.BorderSoft}"
                                BorderThickness="1"
                                FontSize="11"
                                Cursor="Hand"
                                Click="AddFolderBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Theme.ItemSelect}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ RESIZE GRIP — overlaid on the open edge ════════════════ -->
        <Border x:Name="ResizeGrip"
                Width="6"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Cursor="SizeWE"
                Background="Transparent"
                MouseLeftButtonDown="ResizeGrip_MouseDown"
                MouseMove="ResizeGrip_MouseMove"
                MouseLeftButtonUp="ResizeGrip_MouseUp"/>

        <!-- ═══ COLLAPSED tab (shown only when collapsed) ═══════════════ -->
        <Border x:Name="CollapsedTab"
                Visibility="Collapsed"
                CornerRadius="6,0,0,6"
                BorderBrush="{DynamicResource Theme.BorderBrush}"
                BorderThickness="1,1,0,1"
                Cursor="Hand"
                ToolTip="Expand sidebar"
                MouseLeftButtonDown="CollapsedTab_MouseDown">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource Theme.HeaderBg}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1177BB"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Button x:Name="ExpandBtn"
                    Content="▶"
                    FontSize="11"
                    Foreground="#9CDCFE"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CollapseBtn_Click"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False"/>
        </Border>

        <!-- Color picker popup -->
        <Popup x:Name="ColorPickerPopup"
               StaysOpen="False"
               AllowsTransparency="True"
               Placement="MousePoint">
            <Border Background="{DynamicResource Theme.PopupBg}"
                    BorderBrush="{DynamicResource Theme.BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <StackPanel>
                    <TextBlock Text="Folder color"
                               Foreground="{DynamicResource Theme.DimText}"
                               FontSize="11"
                               Margin="0,0,0,6"/>
                    <WrapPanel x:Name="ColorSwatchPanel" Width="156"/>
                    <Button Content="Reset to default"
                            Margin="0,6,0,0"
                            FontSize="11"
                            Foreground="{DynamicResource Theme.DimText}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Left"
                            Click="ColorReset_Click"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Rename popup -->
        <Popup x:Name="RenamePopup"
               StaysOpen="False"
               AllowsTransparency="True"
               Placement="MousePoint">
            <Border Background="{DynamicResource Theme.PopupBg}"
                    BorderBrush="{DynamicResource Theme.BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <StackPanel Width="180">
                    <TextBlock Text="Rename folder"
                               Foreground="{DynamicResource Theme.DimText}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="RenameBox"
                             Background="{DynamicResource Theme.SidebarBg}"
                             Foreground="{DynamicResource Theme.PrimaryText}"
                             BorderBrush="{DynamicResource Theme.BorderSoft}"
                             BorderThickness="1"
                             Padding="4,3"
                             FontSize="12"
                             KeyDown="RenameBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,6,0,0">
                        <Button Content="OK"
                                Width="48" Height="24"
                                Margin="0,0,4,0"
                                Background="#0E639C"
                                Foreground="#FFFFFF"
                                BorderThickness="0"
                                FontSize="11"
                                Cursor="Hand"
                                Click="RenameOk_Click"/>
                        <Button Content="Cancel"
                                Width="48" Height="24"
                                Background="{DynamicResource Theme.ItemSelect}"
                                Foreground="{DynamicResource Theme.SecondaryText}"
                                BorderThickness="0"
                                FontSize="11"
                                Cursor="Hand"
                                Click="RenameCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
        <!-- Group name popup -->
        <Popup x:Name="GroupNamePopup"
               StaysOpen="False"
               AllowsTransparency="True"
               Placement="MousePoint">
            <Border Background="{DynamicResource Theme.PopupBg}"
                    BorderBrush="{DynamicResource Theme.BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <StackPanel Width="180">
                    <TextBlock Text="New group name"
                               Foreground="{DynamicResource Theme.DimText}"
                               FontSize="11"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="GroupNameBox"
                             Background="{DynamicResource Theme.SidebarBg}"
                             Foreground="{DynamicResource Theme.PrimaryText}"
                             BorderBrush="{DynamicResource Theme.BorderSoft}"
                             BorderThickness="1"
                             Padding="4,3"
                             FontSize="12"
                             KeyDown="GroupNameBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,6,0,0">
                        <Button Content="OK"
                                Width="48" Height="24"
                                Margin="0,0,4,0"
                                Background="#0E639C"
                                Foreground="#FFFFFF"
                                BorderThickness="0"
                                FontSize="11"
                                Cursor="Hand"
                                Click="GroupOk_Click"/>
                        <Button Content="Cancel"
                                Width="48" Height="24"
                                Background="{DynamicResource Theme.ItemSelect}"
                                Foreground="{DynamicResource Theme.SecondaryText}"
                                BorderThickness="0"
                                FontSize="11"
                                Cursor="Hand"
                                Click="GroupCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
