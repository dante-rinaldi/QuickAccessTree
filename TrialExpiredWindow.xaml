<Window x:Class="SidebarBuddy.TrialExpiredWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sidebar Buddy — Trial Expired"
        Width="440" Height="380"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

    <Border Background="#13131A"
            BorderBrush="#2A2A3E"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="#0D0D10"
                    CornerRadius="10,10,0,0"
                    Padding="18,12"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="Sidebar Buddy"
                               Foreground="#9090B0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            Foreground="#666680"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="32,24,32,28">

                <!-- Icon + heading -->
                <TextBlock Text="⏱" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Your free trial has ended."
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#E8E8F0"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Enter your license key below to keep using Sidebar Buddy, or visit the website to purchase."
                           Foreground="#7878A0"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,24"/>

                <!-- Email -->
                <TextBlock Text="Email address" Foreground="#9090B0" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="EmailBox"
                         Background="#1C1C2E"
                         Foreground="#E8E8F0"
                         BorderBrush="#2A2A3E"
                         BorderThickness="1"
                         Padding="8,6"
                         FontSize="13"
                         Margin="0,0,0,10"/>

                <!-- Key -->
                <TextBlock Text="License key" Foreground="#9090B0" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="KeyBox"
                         Background="#1C1C2E"
                         Foreground="#E8E8F0"
                         BorderBrush="#2A2A3E"
                         BorderThickness="1"
                         Padding="8,6"
                         FontSize="13"
                         CharacterCasing="Upper"
                         Margin="0,0,0,6"/>

                <!-- Error -->
                <TextBlock x:Name="ErrorText"
                           Foreground="#FF6B6B"
                           FontSize="11"
                           Margin="0,0,0,14"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BuyBtn"
                            Grid.Column="0"
                            Content="Buy Now — $9.99"
                            Height="36"
                            Background="#1A3A5C"
                            Foreground="#7BBFFF"
                            BorderBrush="#2A5A8C"
                            BorderThickness="1"
                            FontSize="12"
                            Cursor="Hand"
                            Click="BuyNow_Click"/>
                    <Button x:Name="ActivateBtn"
                            Grid.Column="2"
                            Content="Activate"
                            Height="36"
                            Background="#0E639C"
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="Activate_Click"/>
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</Window>
