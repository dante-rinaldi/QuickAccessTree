<Window x:Class="SidebarBuddy.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="520" Height="540"
        MinWidth="520" MinHeight="480"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Nav item -->
        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="Foreground"      Value="#9090A0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Outer" Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Accent" Background="Transparent"/>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="13,9,8,9"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Outer"  Property="Background"  Value="#2A2A2E"/>
                                <Setter TargetName="Accent" Property="Background"  Value="#0E639C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Outer" Property="Background" Value="#26262B"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#606070"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,18,0,6"/>
        </Style>

        <!-- Settings RadioButton -->
        <Style x:Key="SettingsRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,3,0,0"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- Settings CheckBox -->
        <Style x:Key="SettingsCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,4,0,0"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- Generic dark button template -->
        <ControlTemplate x:Key="DarkBtnTpl" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Standard dark button -->
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2D2D30"/>
            <Setter Property="Foreground"      Value="#CCCCCC"/>
            <Setter Property="BorderBrush"     Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource DarkBtnTpl}"/>
        </Style>

        <!-- Accent button (blue) -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background"      Value="#0E639C"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderBrush"     Value="#1C84D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template"        Value="{StaticResource DarkBtnTpl}"/>
        </Style>

        <!-- Skin list item -->
        <Style x:Key="SkinItem" TargetType="ListBoxItem">
            <Setter Property="Foreground"      Value="#DCDCDC"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Margin="2,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#37373D"/>
                                <Setter Property="Foreground" Value="#9CDCFE"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#2D2D30"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer frame -->
    <Border Background="#1E1E1E"
            CornerRadius="8"
            BorderBrush="#555555"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- ══ Header ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="#252526"
                    CornerRadius="8,8,0,0"
                    BorderBrush="#3C3C3C"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Header_MouseDown"
                    Cursor="SizeAll">
                <Grid Margin="14,0,8,0">
                    <TextBlock Text="⚙  Settings"
                               Foreground="#CCCCCC"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <!-- Close X -->
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="28" Height="28"
                            Foreground="#808080"
                            FontSize="12"
                            Click="Close_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="✕"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ══ Body ═════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left nav -->
                <Border Background="#252526"
                        BorderBrush="#3C3C3C"
                        BorderThickness="0,0,1,0">
                    <ListBox x:Name="NavList"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,8,0,0"
                             SelectionChanged="NavList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavItem}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBoxItem Content="General"    Tag="General"/>
                        <ListBoxItem Content="Appearance" Tag="Appearance"/>
                        <ListBoxItem Content="License"    Tag="License"/>
                    </ListBox>
                </Border>

                <!-- Content panels -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <Grid>

                    <!-- ── General ─────────────────────────────────────── -->
                    <StackPanel x:Name="PanelGeneral" Margin="22,10,22,20">

                        <TextBlock Text="COLOR INHERITANCE"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,4,0,6"/>
                        <RadioButton x:Name="RbColorPerFolder"
                                     Content="Per folder only"
                                     Style="{StaticResource SettingsRadio}"
                                     GroupName="ColorMode"
                                     Checked="Setting_Changed"/>
                        <RadioButton x:Name="RbColorCascade"
                                     Content="Cascade color to all subfolders"
                                     Style="{StaticResource SettingsRadio}"
                                     GroupName="ColorMode"
                                     Checked="Setting_Changed"/>

                        <TextBlock Text="SIDEBAR BEHAVIOR" Style="{StaticResource SectionLabel}"/>
                        <RadioButton x:Name="RbStayVisible"
                                     Content="Stay visible (always on screen)"
                                     Style="{StaticResource SettingsRadio}"
                                     GroupName="AutoHide"
                                     Checked="Setting_Changed"/>
                        <RadioButton x:Name="RbAutoHide"
                                     Content="Auto-hide with Explorer"
                                     Style="{StaticResource SettingsRadio}"
                                     GroupName="AutoHide"
                                     Checked="Setting_Changed"/>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RbAutoHide}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity"   Value="0.38"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="VISIBILITY DELAY" Style="{StaticResource SectionLabel}"/>
                            <RadioButton x:Name="RbDelayInstant"
                                         Content="Instant"
                                         Style="{StaticResource SettingsRadio}"
                                         GroupName="Delay"
                                         Checked="Setting_Changed"/>
                            <RadioButton x:Name="RbDelayHalf"
                                         Content="0.5 seconds"
                                         Style="{StaticResource SettingsRadio}"
                                         GroupName="Delay"
                                         Checked="Setting_Changed"/>
                            <RadioButton x:Name="RbDelayTwo"
                                         Content="2 seconds"
                                         Style="{StaticResource SettingsRadio}"
                                         GroupName="Delay"
                                         Checked="Setting_Changed"/>
                            <RadioButton x:Name="RbDelayFive"
                                         Content="5 seconds"
                                         Style="{StaticResource SettingsRadio}"
                                         GroupName="Delay"
                                         Checked="Setting_Changed"/>
                        </StackPanel>

                        <TextBlock Text="DEFAULT DOCK SIDE" Style="{StaticResource SectionLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RbDockLeft"
                                         Content="Left"
                                         Style="{StaticResource SettingsRadio}"
                                         GroupName="DockSide"
                                         Margin="0,3,20,0"
                                         Checked="Setting_Changed"/>
                            <RadioButton x:Name="RbDockRight"
                                         Content="Right"
                                         Style="{StaticResource SettingsRadio}"
                                         GroupName="DockSide"
                                         Checked="Setting_Changed"/>
                        </StackPanel>

                        <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionLabel}"/>
                        <CheckBox x:Name="CbStartup"
                                  Content="Launch on startup"
                                  Style="{StaticResource SettingsCheck}"
                                  Click="Setting_Changed"/>
                        <CheckBox x:Name="CbRestoreExpanded"
                                  Content="Restore expanded state on launch"
                                  Style="{StaticResource SettingsCheck}"
                                  Click="Setting_Changed"/>

                        <TextBlock Text="ADD FOLDER BUTTON" Style="{StaticResource SectionLabel}"/>
                        <RadioButton x:Name="RbAddCurrent"
                                     Content="Add current Explorer folder instantly"
                                     Style="{StaticResource SettingsRadio}"
                                     GroupName="AddFolder"
                                     Checked="Setting_Changed"/>
                        <RadioButton x:Name="RbAddSelected"
                                     Content="Add selected item in Explorer"
                                     Style="{StaticResource SettingsRadio}"
                                     GroupName="AddFolder"
                                     Checked="Setting_Changed"/>
                        <RadioButton x:Name="RbAddBrowse"
                                     Content="Open folder browser dialog"
                                     Style="{StaticResource SettingsRadio}"
                                     GroupName="AddFolder"
                                     Checked="Setting_Changed"/>

                        <TextBlock Text="QUICK LINKS" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="Pin shortcuts in the sidebar for quick navigation."
                                   Foreground="#666680" FontSize="11" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <CheckBox x:Name="CbShowThisPC"
                                  Content="Show 'This PC'"
                                  Style="{StaticResource SettingsCheck}"
                                  Click="Setting_Changed"/>
                        <CheckBox x:Name="CbShowControlPanel"
                                  Content="Show 'Control Panel'"
                                  Style="{StaticResource SettingsCheck}"
                                  Click="Setting_Changed"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <RadioButton x:Name="RbQuickLinksTop"
                                         Content="Pin to top"
                                         Style="{StaticResource SettingsRadio}"
                                         GroupName="QuickLinks"
                                         Margin="0,3,16,0"
                                         Checked="Setting_Changed"/>
                            <RadioButton x:Name="RbQuickLinksBottom"
                                         Content="Pin to bottom"
                                         Style="{StaticResource SettingsRadio}"
                                         GroupName="QuickLinks"
                                         Checked="Setting_Changed"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── Appearance ──────────────────────────────────── -->
                    <StackPanel x:Name="PanelAppearance" Margin="22,10,22,20"
                                Visibility="Collapsed">

                        <TextBlock Text="THEME"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,4,0,6"/>
                        <RadioButton x:Name="RbThemeSystem"
                                     Content="Follow system"
                                     Style="{StaticResource SettingsRadio}"
                                     GroupName="Theme"
                                     Checked="Setting_Changed"/>
                        <RadioButton x:Name="RbThemeDark"
                                     Content="Dark"
                                     Style="{StaticResource SettingsRadio}"
                                     GroupName="Theme"
                                     Checked="Setting_Changed"/>
                        <RadioButton x:Name="RbThemeLight"
                                     Content="Light"
                                     Style="{StaticResource SettingsRadio}"
                                     GroupName="Theme"
                                     Checked="Setting_Changed"/>

                        <TextBlock Text="FONT &amp; ICON SIZE" Style="{StaticResource SectionLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="FontScaleSlider"
                                    Minimum="0.75" Maximum="1.75"
                                    SmallChange="0.05" LargeChange="0.25"
                                    TickFrequency="0.25" IsSnapToTickEnabled="False"
                                    Foreground="#0E639C"
                                    ValueChanged="FontScaleSlider_ValueChanged"/>
                            <TextBlock x:Name="FontScaleLabel"
                                       Grid.Column="1"
                                       Foreground="#DCDCDC"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="SKIN" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="Skins change the visual style of the sidebar."
                                   Foreground="#666680" FontSize="11" Margin="0,0,0,6"/>
                        <ListBox x:Name="SkinList"
                                 Background="#252526"
                                 BorderBrush="#3C3C3C"
                                 BorderThickness="1"
                                 MaxHeight="190"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="Skin_Changed">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource SkinItem}"/>
                            </ListBox.ItemContainerStyle>
                            <ListBoxItem Content="Solid Dark"/>
                            <ListBoxItem Content="Solid Light"/>
                            <ListBoxItem Content="Frosted Glass"/>
                            <ListBoxItem Content="Mica"/>
                            <ListBoxItem Content="Neon Cyber"/>
                            <ListBoxItem Content="Terminal"/>
                            <ListBoxItem Content="Paper"/>
                            <ListBoxItem Content="Synthwave"/>
                            <ListBoxItem Content="Brushed Metal"/>
                            <ListBoxItem Content="High Contrast"/>
                        </ListBox>
                        <TextBlock Text="Note: Skins beyond Solid Dark are coming in a future update."
                                   Foreground="#4A4A5E" FontSize="10" FontStyle="Italic"
                                   Margin="0,5,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- ── License ─────────────────────────────────────── -->
                    <StackPanel x:Name="PanelLicense" Margin="22,10,22,20"
                                Visibility="Collapsed">

                        <TextBlock Text="SIDEBAR BUDDY"
                                   Foreground="#9CDCFE"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,6"/>

                        <TextBlock x:Name="LicenseStatusText"
                                   Foreground="#CCCCCC"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <Button x:Name="BuyNowBtn"
                                Content="Buy Now — Unlock Full Version"
                                Style="{StaticResource AccentBtn}"
                                HorizontalAlignment="Left"
                                Height="30"
                                Padding="16,0"
                                Click="BuyNow_Click"/>

                        <TextBlock Text="ACTIVATION" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="Enter your license key to activate:"
                                   Foreground="#666680" FontSize="11" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="82"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LicenseKeyBox"
                                     Background="#161618"
                                     Foreground="#DCDCDC"
                                     CaretBrush="#DCDCDC"
                                     BorderBrush="#4A4A50"
                                     BorderThickness="1"
                                     Padding="7,5"
                                     FontSize="12"
                                     FontFamily="Consolas"
                                     Margin="0,0,8,0"
                                     MaxLength="64"/>
                            <Button Grid.Column="1"
                                    Content="Activate"
                                    Style="{StaticResource DarkBtn}"
                                    Click="ActivateLicense_Click"/>
                        </Grid>

                        <TextBlock x:Name="LicenseErrorText"
                                   Foreground="#FF5555"
                                   FontSize="11"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                  </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ══ Footer ════════════════════════════════════════════════════ -->
            <Border Grid.Row="2"
                    Background="#252526"
                    CornerRadius="0,0,8,8"
                    BorderBrush="#3C3C3C"
                    BorderThickness="0,1,0,0">
                <Button Content="Close"
                        Style="{StaticResource DarkBtn}"
                        Width="76"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0"
                        Click="Close_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
