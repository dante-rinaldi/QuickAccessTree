<Application x:Class="SidebarBuddy.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Theme resource stubs — overwritten at runtime by ThemeManager.Apply() -->
        <SolidColorBrush x:Key="Theme.SidebarBg"     Color="#1E1E1E"/>
        <SolidColorBrush x:Key="Theme.HeaderBg"      Color="#252526"/>
        <SolidColorBrush x:Key="Theme.PopupBg"       Color="#2D2D30"/>
        <SolidColorBrush x:Key="Theme.BorderBrush"   Color="#3C3C3C"/>
        <SolidColorBrush x:Key="Theme.BorderSoft"    Color="#555555"/>
        <SolidColorBrush x:Key="Theme.ItemHover"     Color="#2D2D30"/>
        <SolidColorBrush x:Key="Theme.ItemSelect"    Color="#37373D"/>
        <SolidColorBrush x:Key="Theme.PrimaryText"   Color="#DCDCDC"/>
        <SolidColorBrush x:Key="Theme.SecondaryText" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="Theme.DimText"       Color="#707070"/>
        <SolidColorBrush x:Key="Theme.ScrollThumb"   Color="#555555"/>
        <!-- Font/icon scale — updated at runtime by ThemeManager.ApplyFontScale() -->
        <sys:Double x:Key="Theme.FontSize">12</sys:Double>
        <sys:Double x:Key="Theme.IconWidth">16</sys:Double>
        <sys:Double x:Key="Theme.IconHeight">13</sys:Double>
    </Application.Resources>
</Application>
